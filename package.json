{
  "name": "world-sizes",
  "version": "1.0.0",
  "description": "ArcGIS Maps SDK app to compare contries and regions",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/arnofiva/world-sizes"
  },
  "private": true,
  "type": "module",
  "author": "Esri",
  "license": "Apache-2.0",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "serve": "vite preview",
    "lint": "npm run typecheck && eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@arcgis/core": "^5.0.0",
    "@arcgis/map-components": "^5.0.0",
    "@esri/calcite-components": "^5.0.2",
    "gl-matrix": "^3.4.4",
    "jszip": "^3.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intl": "^7.1.14",
    "simplify-js": "^1.2.4"
  },
  "devDependencies": {
    "@arcgis/codemod": "^5.0.2",
    "@eslint/js": "^9.38.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-headers": "^1.3.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "markdown-it": "^14.1.0",
    "prettier": "^2.8.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.3.5"
  }
}
